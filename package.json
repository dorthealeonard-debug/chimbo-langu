{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:server": "esbuild server/server.ts --bundle --platform=node --outfile=dist/server.js --format=esm --external:express --external:dotenv",
    "preview": "vite preview",
